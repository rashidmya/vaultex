/* ==========================================================================
   VAULTEX HEXO THEME — Entry Point
   Imports all partials in dependency order.
   ========================================================================== */

/* 0. Web fonts (Inter + Source Code Pro) */
@import '_fonts'

/* 1. Design tokens */
@import '_variables'

/* 2. Base reset & scrollbars */
@import '_base'

/* 3. App shell layout */
@import '_layout'

/* 4. Sidebar navigation */
@import '_navigation'

/* 5. Right panel: TOC, tags, related */
@import '_toc'

/* 6. Shared UI components: tag pills, pagination, callouts */
@import '_components'

/* 7. Post list, article, archive, categories, tags pages */
@import '_post'

/* 8. Markdown body: headings, text, links, lists, blockquotes, tables, images */
@import '_markdown'

/* 9. Code blocks & syntax highlighting */
@import '_code'

/* 10. Search page */
@import '_search'

/* 11. Utility classes */
@import '_utilities'

/* 12. Responsive breakpoints, focus/a11y, reduced-motion */
@import '_responsive'

/* 13. Print styles */
@import '_print'

/* 14. Help modal */
@import '_help-modal'

/* 15. Quick switcher */
@import '_quick-switcher'

/* 16. Syntax highlight theme */
@import '_highlight/' + highlight-theme


