<%
var currentPath = page.path || '';
var sidebar = theme.left_sidebar || {};
var explorer = sidebar.explorer || {};
var explorerStyle = explorer.style || 2;
var explorerNumbers = explorer.numbers !== false;
var navIcons = sidebar.show_nav_icons !== false;
var categoryIcons = sidebar.show_category_icons !== false;
var linksIcons = sidebar.show_links_icons !== false;
function isActive(navPath, exact) {
  var p = navPath.replace(/^\/|\/$/g, '');
  var c = currentPath.replace(/index\.html$/, '').replace(/^\/|\/$/g, '');
  if (p === '' && c === '') return true;
  if (p !== '') return exact ? p === c : c.startsWith(p);
  return false;
}
%>

<div class="sidebar-left-inner">

  <!-- ============ FOLDER TAB ============ -->
  <div class="sidebar-tab-content<% if (explorerStyle === 1) { %> explorer-style-1<% } %>" data-tab="folder">

    <!-- Site identity: logo, title, description -->
    <div class="sidebar-site-header">
      <a href="<%- url_for('/') %>" class="sidebar-site-title" aria-label="Go to homepage">
        <% var logo = theme.customize && theme.customize.logo; %>
        <% if (logo && logo.enabled && logo.url) { %>
        <img src="<%- url_for(logo.url) %>" class="sidebar-site-logo" width="<%= logo.width || 20 %>" height="<%= logo.height || 20 %>" alt="" aria-hidden="true">
        <% } else { %>
        <%- partial('_partial/icon', {name: 'house', size: 18, cls: 'sidebar-site-logo-icon'}) %>
        <% } %>
        <span class="sidebar-site-name"><%- config.title || 'Vaultex' %></span>
      </a>
      <% if (config.description) { %>
      <p class="sidebar-site-description"><%= config.description %></p>
      <% } %>
    </div>

    <!-- Explorer action bar -->
    <div class="explorer-actions">
      <button class="explorer-action-btn" id="explorer-auto-reveal" title="Auto-reveal current file" aria-label="Auto-reveal current file">
        <%- partial('_partial/icon', {name: 'gallery-vertical', size: 18}) %>
      </button>
      <button class="explorer-action-btn is-expanded" id="explorer-collapse-all" title="Expand all" aria-label="Expand all">
        <%- partial('_partial/icon', {name: 'chevrons-down-up', size: 18, cls: 'icon-collapse-svg'}) %>
        <%- partial('_partial/icon', {name: 'chevrons-up-down', size: 18, cls: 'icon-expand-svg'}) %>
      </button>
    </div>

    <!-- Navigation (driven by theme.nav_items in _config.yml) -->
    <% if (theme.nav_items && theme.nav_items.length) { %>
    <div class="explorer-section">
      <div class="explorer-section-header" data-section="nav">
        <%- partial('_partial/icon', {name: 'chevron-down', size: 16, cls: 'chevron', sw: 2.5}) %>
        <span><%= explorerStyle === 1 ? 'NAVIGATION' : (explorerNumbers ? '00 Navigation' : 'Navigation') %></span>
      </div>
      <nav class="nav-tree" id="nav-nav">
        <% theme.nav_items.forEach(function(item) { %>
        <a href="<%- url_for(item.path) %>" class="nav-item<% if (isActive(item.path)) { %> active<% } %>">
          <% if (navIcons) { %><%- partial('_partial/icon', {name: item.icon || 'file', size: 14, cls: 'nav-icon-svg'}) %><% } %>
          <span class="nav-label"><%= item.label %></span>
        </a>
        <% }) %>
      </nav>
    </div>
    <% } %>

    <!-- Categories tree -->
    <% if (site.categories.length > 0) { %>
    <div class="explorer-section">
      <div class="explorer-section-header" data-section="categories">
        <%- partial('_partial/icon', {name: 'chevron-down', size: 15, cls: 'chevron', sw: 2.5}) %>
        <span><%= explorerStyle === 1 ? 'CATEGORIES' : (explorerNumbers ? '10 Categories' : 'Categories') %></span>
      </div>
      <div class="nav-tree" id="nav-categories">
        <%
          var allCats = site.categories.toArray();
          function getCatChildren(pid) {
            return allCats
              .filter(function(c) { return c.parent && String(c.parent) === String(pid); })
              .sort(function(a, b) { return a.name.localeCompare(b.name); });
          }
          var catRoots = allCats
            .filter(function(c) { return !c.parent; })
            .sort(function(a, b) { return a.name.localeCompare(b.name); });
          var treeItems = [];
          function flattenCatTree(cats, depth) {
            cats.forEach(function(cat) {
              var children = getCatChildren(cat._id);
              treeItems.push({ cat: cat, depth: depth, hasChildren: children.length > 0 });
              flattenCatTree(children, depth + 1);
            });
          }
          flattenCatTree(catRoots, 0);
        %>
        <% treeItems.forEach(function(item) { %>
        <%
          var cat = item.cat;
          var depth = item.depth;
          var indent = explorerStyle === 1 ? 16 + depth * 20 : 32 + depth * 16;
          var tid = 'ct-' + cat._id;
          var pid = cat.parent ? 'ct-' + cat.parent : '';
        %>
        <% if (item.hasChildren) { %>
        <div class="nav-item nav-tree-parent<% if (isActive('/' + cat.path, true)) { %> active<% } %>"
             data-tree-id="<%= tid %>"
             data-parent-tree-id="<%= pid %>"
             data-depth="<%= depth %>"
             data-tree-open="true"
             style="padding-left:<%= indent %>px">
          <button class="tree-toggle-btn" aria-label="Toggle <%= cat.name %>">
            <%- partial('_partial/icon', {name: 'chevron-down', size: 15, cls: 'nav-icon-svg tree-chevron', sw: 2.5}) %>
          </button>
          <a href="<%- url_for(cat.path) %>" class="nav-tree-label">
            <% if (categoryIcons) { %><%- partial('_partial/icon', {name: 'folder', size: 14, cls: 'nav-icon-svg folder-icon'}) %><% } %>
            <span class="nav-label"><%= cat.name %></span>
          </a>
        </div>
        <% } else { %>
        <a href="<%- url_for(cat.path) %>"
           class="nav-item nav-tree-leaf<% if (isActive('/' + cat.path)) { %> active<% } %>"
           data-tree-id="<%= tid %>"
           data-parent-tree-id="<%= pid %>"
           data-depth="<%= depth %>"
           style="padding-left:<%= indent %>px">
          <% if (categoryIcons) { %><%- partial('_partial/icon', {name: 'file-text', size: 14, cls: 'nav-icon-svg nav-leaf-icon'}) %><% } else { %><span style="width:14px;flex-shrink:0"></span><% } %>
          <span class="nav-label"><%= cat.name %></span>
        </a>
        <% } %>
        <% }) %>
      </div>
    </div>
    <script>
    /* Synchronously hide category items whose ancestors are collapsed.
       Runs inline (no defer/module delay) to prevent the flash caused by
       the module script restoring state after first paint. */
    (function () {
      try {
        var cats = document.getElementById('nav-categories');
        if (!cats) return;
        cats.querySelectorAll('[data-depth]').forEach(function (item) {
          var pid = item.dataset.parentTreeId;
          while (pid) {
            var saved = localStorage.getItem('obs-' + pid);
            if (saved === '0') { item.style.display = 'none'; return; }
            var parentEl = cats.querySelector('[data-tree-id="' + pid + '"]');
            if (!parentEl) break;
            pid = parentEl.dataset.parentTreeId;
          }
        });
      } catch (_) {}
    }());
    </script>
    <% } %>

    <!-- Social links -->
    <% if (theme.social_links && theme.social_links.length) { %>
    <div class="explorer-section">
      <div class="explorer-section-header" data-section="social">
        <%- partial('_partial/icon', {name: 'chevron-down', size: 15, cls: 'chevron', sw: 2.5}) %>
        <span><%= explorerStyle === 1 ? 'LINKS' : (explorerNumbers ? '20 Links' : 'Links') %></span>
      </div>
      <div class="nav-tree" id="nav-social">
        <% theme.social_links.forEach(function(link) { %>
        <a href="<%= link.url %>" class="nav-item" target="_blank" rel="noopener noreferrer">
          <% if (linksIcons) { %><%- partial('_partial/icon', {name: link.icon || 'link', size: 14, cls: 'nav-icon-svg'}) %><% } %>
          <span class="nav-label"><%= link.label %></span>
        </a>
        <% }) %>
      </div>
    </div>
    <% } %>

  </div><!-- /.sidebar-tab-content[folder] -->

  <!-- ============ SEARCH TAB ============ -->
  <div class="sidebar-tab-content sidebar-tab-hidden" data-tab="search">
    <div class="sidebar-search-panel">

      <!-- SearchHeader: rounded input + filter button outside -->
      <div class="search-input-row">
        <div class="sidebar-search-box">
          <%- partial('_partial/icon', {name: 'search', size: 18, cls: 'search-icon-svg'}) %>
          <input
            type="search"
            id="search-input"
            placeholder="<%= 'Search...' %>"
            autocomplete="off"
            spellcheck="false"
            aria-label="Search notes"
          >
          <button class="search-btn-aa" id="search-match-case" title="Match case" aria-label="Match case" aria-pressed="false">Aa</button>
          <button class="search-btn-clear" id="search-clear" title="Clear search" aria-label="Clear search" hidden>
            <%- partial('_partial/icon', {name: 'circle-x', size: 14, sw: 2}) %>
          </button>
        </div>
        <button class="search-btn-filter" id="search-filter-btn" title="Filter options" aria-label="Filter options" aria-pressed="false">
          <%- partial('_partial/icon', {name: 'sliders-horizontal', size: 18, sw: 1.875}) %>
        </button>
      </div>

      <!-- Filter panel (toggled by filter button) -->
      <div class="search-filter-panel" id="search-filter-panel" hidden>
        <label class="search-filter-row">
          <span class="search-filter-label">Collapse results</span>
          <span class="toggle-wrap">
            <input type="checkbox" id="filter-collapse-results" class="toggle-input" autocomplete="off">
            <span class="toggle-track"></span>
          </span>
        </label>
        <label class="search-filter-row">
          <span class="search-filter-label">Show more context</span>
          <span class="toggle-wrap">
            <input type="checkbox" id="filter-more-context" class="toggle-input" autocomplete="off">
            <span class="toggle-track"></span>
          </span>
        </label>
      </div>

      <!-- SearchToolbar: count + sort (hidden until there are results) -->
      <div class="search-toolbar" id="search-toolbar" hidden>
        <span class="search-count-label" id="search-results-count"></span>
        <div class="dropdown-wrap">
          <button class="search-sort-btn" id="search-sort-btn" aria-expanded="false" aria-label="Sort results">
            <span id="search-sort-label">File name (A to Z)</span>
            <%- partial('_partial/icon', {name: 'chevrons-up-down', size: 14, sw: 2.2}) %>
          </button>
          <div class="dropdown dropdown-right" id="search-sort-dropdown" hidden>
            <button class="dropdown-item active" data-sort="name-asc">
              <span>File name (A to Z)</span>
              <%- partial('_partial/icon', {name: 'check', size: 14, cls: 'dropdown-check'}) %>
            </button>
            <button class="dropdown-item" data-sort="name-desc">
              <span>File name (Z to A)</span>
              <%- partial('_partial/icon', {name: 'check', size: 14, cls: 'dropdown-check'}) %>
            </button>
            <div class="dropdown-sep"></div>
            <button class="dropdown-item" data-sort="modified-desc">
              <span>Modified time (new to old)</span>
              <%- partial('_partial/icon', {name: 'check', size: 14, cls: 'dropdown-check'}) %>
            </button>
            <button class="dropdown-item" data-sort="modified-asc">
              <span>Modified time (old to new)</span>
              <%- partial('_partial/icon', {name: 'check', size: 14, cls: 'dropdown-check'}) %>
            </button>
            <div class="dropdown-sep"></div>
            <button class="dropdown-item" data-sort="created-desc">
              <span>Created time (new to old)</span>
              <%- partial('_partial/icon', {name: 'check', size: 14, cls: 'dropdown-check'}) %>
            </button>
            <button class="dropdown-item" data-sort="created-asc">
              <span>Created time (old to new)</span>
              <%- partial('_partial/icon', {name: 'check', size: 14, cls: 'dropdown-check'}) %>
            </button>
          </div>
        </div>
      </div>

      <!-- Results -->
      <div class="sidebar-search-results">
        <div id="search-results" role="list"></div>
        <div id="search-no-results">
          <p>No matches found.</p>
        </div>
      </div>

    </div>
  </div><!-- /.sidebar-tab-content[search] -->

  <!-- Vault Footer — persists across folder/search tabs -->
  <div class="vault vault-footer">
    <%- partial('_partial/vault') %>
  </div>

</div>
