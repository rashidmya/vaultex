<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta http-equiv="X-UA-Compatible" content="IE=edge">

<title><% if (page.title) { %><%= page.title %> | <%= config.title %><% } else { %><%= config.title %><% } %></title>

<% if (config.description) { %>
<meta name="description" content="<%= config.description %>">
<% } %>
<% if (config.keywords) { %>
<meta name="keywords" content="<%= config.keywords %>">
<% } %>
<meta name="author" content="<%= config.author %>">
<% if (page.meta && page.meta.length) { %><%- meta(page) %><% } %>

<!-- Open Graph -->
<meta property="og:title" content="<% if (page.title) { %><%= page.title %><% } else { %><%= config.title %><% } %>">
<meta property="og:type" content="<% if (page.layout === 'post') { %>article<% } else { %>website<% } %>">
<meta property="og:url" content="<%- page.permalink || config.url %>">
<meta property="og:site_name" content="<%= config.title %>">
<% if (config.description) { %><meta property="og:description" content="<%= config.description %>"><% } %>

<!-- Canonical -->
<link rel="canonical" href="<%- page.permalink || config.url %>">

<!-- RSS Feed -->
<% if (config.feed && config.feed.path) { %>
<link rel="alternate" type="application/atom+xml" title="<%= config.title %>" href="<%- url_for(config.feed.path) %>">
<% } %>

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="<%- url_for('/favicon.svg') %>">

<!-- Theme CSS -->
<link rel="stylesheet" href="<%- url_for('/css/style.css') %>">


<% if (theme.customize && theme.customize.font_size) { %>
<style>:root { --font-size-base: <%= theme.customize.font_size %>px; }</style>
<% } %>
<% if (theme.customize && theme.customize.code_font_size) { %>
<style>:root { --font-size-code: <%= theme.customize.code_font_size %>px; }</style>
<% } %>
<% if (theme.customize && theme.customize.max_content_width) { %>
<style>:root { --content-max-width: <%= theme.customize.max_content_width %>px; }</style>
<% } %>
<script>
/* FOUC prevention: read localStorage before first paint and set data attrs on <html>.
   CSS rules below use these attrs to apply correct initial sidebar state.
   JS removes them after taking over. */
(function () {
  try {
    var w = window.innerWidth;
    var l = localStorage.getItem('obs-left-open');
    var r = localStorage.getItem('obs-right-open');
    if (w <= 768 || l === '0') document.documentElement.setAttribute('data-vx-left', 'closed');
    if (w > 900  && r === '1') document.documentElement.setAttribute('data-vx-right', 'open');
    /* Disable transitions during init to prevent chevron animations on load */
    document.documentElement.setAttribute('data-vx-init', '');
    /* Collapsed explorer sections + pre-rotate their chevrons */
    var hidden = [], sectionChevrons = [];
    for (var i = 0; i < localStorage.length; i++) {
      var k = localStorage.key(i);
      if (!k) continue;
      var v = localStorage.getItem(k);
      if (k.startsWith('obs-section-') && v === '0') {
        var sid = k.slice('obs-section-'.length);
        hidden.push('#nav-' + sid);
        sectionChevrons.push('.explorer-section-header[data-section="' + sid + '"] .chevron');
      }
    }
    var css = '';
    if (hidden.length)          css += hidden.join(',')          + '{display:none}';
    if (sectionChevrons.length) css += sectionChevrons.join(',') + '{transform:rotate(-90deg)}';
    if (css) {
      var st = document.createElement('style');
      st.id = 'vx-sections-init';
      st.textContent = css;
      document.head.appendChild(st);
    }
  } catch (_) {}
}());
</script>
<script>window.VAULTEX_CONFIG = { toc: <%= (theme.sidebar_right && theme.sidebar_right.toc) !== false %>, tocDepth: <%= (theme.sidebar_right && theme.sidebar_right.toc_depth) || 3 %>, postsPerRow: <%= theme.posts_per_row || 1 %>, searchXml: '<%- url_for('/search.xml') %>' };</script>
